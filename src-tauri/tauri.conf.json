{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rush ID",
  "version": "1.0.0",
  "identifier": "com.j3ffprinting.rush-id",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rush ID — J3FF PRINTING SERVICES",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "SVGs/*": "SVGs/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDQUZFRDFBNDJFNDEyODQKUldTRUV1UkNHdTJ2ak9ZS08zRkl3VEF4WmJ4TFVvaHhMOElqNElYTm1rd2NuODRubmU1Y2sreFgK",
      "endpoints": [
        "https://github.com/jrchioco/rush_id_tauri/releases/latest/download/updates.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
